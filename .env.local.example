# GitHub OAuth — free at:
# github.com/settings/developers → New OAuth App
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:3000/api/github/callback

# Discord OAuth — free at:
# discord.com/developers/applications → New Application
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:3000/api/discord/callback

# Farcaster — NO KEYS NEEDED (wallet-based auth)

# App config
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_RIALO_RPC_URL=https://devnet.rialo.io
NEXT_PUBLIC_CONTRACT_ADDRESS=PLACEHOLDER
